			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/video_script.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "video_script.json"]
				}
			},
			"response": []
		},
		{
			"name": "Get Resource - Presentation",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/presentation.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "presentation.json"]
				}
			},
			"response": []
