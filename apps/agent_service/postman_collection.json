					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/interactive_lesson.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "interactive_lesson.json"]
				}
			},
			"response": []
		},
		{
			"name": "Get Resource - Concept Map",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/concept_map.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "concept_map.json"]
				}
			},
			"response": []
		},
		{
			"name": "Get Resource - Images",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/images.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "images.json"]
				}
			},
			"response": []
		}
	]
}
