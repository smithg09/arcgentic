{
	"info": {
		"_postman_id": "ai-learning-agent-api",
		"name": "AI Learning Agent API",
		"description": "Multi-agent learning resource generator API. Flow: Create Session → Chat (gather requirements) → Chat (answer follow-ups) → Get Resources.\n\nNOTE: The /chat endpoint now returns a Server-Sent Events (SSE) stream.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:5001",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/health",
					"host": ["{{base_url}}"],
					"path": ["api", "health"]
				}
			},
			"response": []
		},
		{
			"name": "Create Session",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set('session_id', jsonData.session_id);",
							"pm.test('Session created', function () {",
							"    pm.response.to.have.status(201);",
							"    pm.expect(jsonData.session_id).to.be.a('string');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions"]
				}
			},
			"response": []
		},
		{
			"name": "Chat - Initial Topic",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Got streaming response', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"message\": \"I want to learn Docker\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "chat"]
				}
			},
			"response": []
		},
		{
			"name": "Chat - Answer Follow-up (Experience Level)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"message\": \"I'm a beginner, I've never used Docker before\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "chat"]
				}
			},
			"response": []
		},
		{
			"name": "Chat - Answer Follow-up (Focus Areas)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Got streaming response', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/event-stream');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"message\": \"I'm interested in containers, images, and basic deployment with Docker Compose\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "chat"]
				}
			},
			"response": []
		},
		{
			"name": "Chat - With URLs",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"message\": \"Here are some references I found helpful\",\n    \"urls\": [\"https://docs.docker.com/get-started/\"]\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "chat"]
				}
			},
			"response": []
		},
		{
			"name": "Chat - With PDF Upload",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "message",
							"value": "I also have this PDF with more context",
							"type": "text"
						},
						{
							"key": "files",
							"type": "file",
							"src": "",
							"description": "Select a PDF file to upload"
						},
						{
							"key": "urls",
							"value": "",
							"type": "text",
							"description": "Comma-separated URLs (optional)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/chat",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "chat"]
				}
			},
			"response": []
		},
		{
			"name": "Get Session Data",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.test('Got session data', function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(jsonData.exists).to.be.true;",
							"    pm.expect(jsonData.messages).to.be.an('array');",
							"    pm.expect(jsonData.resources).to.be.an('object');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}"]
				},
				"description": "Fetch the complete graph state for a session.\n\nReturns:\n- messages: full conversation history\n- spec: learning spec built by the architect\n- sources: PDFs / links provided by the user\n- resources: all generated content files\n- todos: task list maintained by the agent\n- memory: notes stored by the learning agent"
			},
			"response": []
		},
		{
			"name": "Get All Resources",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources"]
				}
			},
			"response": []
		},
		{
			"name": "Get Resource - Article",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/article.md",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "article.md"]
				}
			},
			"response": []
		},
		{
			"name": "Get Resource - Flashcards",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/flashcards.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "flashcards.json"]
				}
			},
			"response": []
