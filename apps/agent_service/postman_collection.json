					"raw": "{{base_url}}/api/sessions/{{session_id}}/resources/podcast.json",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions", "{{session_id}}", "resources", "podcast.json"]
				}
			},
			"response": []
		},
		{
