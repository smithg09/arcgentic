{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "setup": {
      "cache": false
    },
    "gqlgen": {
      "dependsOn": [
        "^gqlgen"
      ],
      "outputs": [
        "cmd/core/graph/**"
      ]
    },
    "sqlc": {
      "dependsOn": [
        "^sqlc"
      ],
      "outputs": [
        "internal/module/**/querier/**"
      ]
    }
  }
}